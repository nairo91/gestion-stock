<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connexion | GROUPE-BR</title>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css"
  >
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
  >
  <style>
    :root {
      --bg-dark: #0f172a;
      --bg-dark-soft: #111d34;
      --surface: #ffffff;
      --surface-soft: #f8fafc;
      --text-main: #0f172a;
      --text-soft: #64748b;
      --brand: #1d4ed8;
      --brand-deep: #1e3a8a;
      --border: rgba(15, 23, 42, 0.12);
      --danger: #b91c1c;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: "Inter", "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      background:
        radial-gradient(circle at 12% 18%, rgba(59, 130, 246, 0.22), transparent 38%),
        radial-gradient(circle at 90% 8%, rgba(30, 64, 175, 0.3), transparent 34%),
        linear-gradient(140deg, #020617 0%, #0b1223 55%, #17263f 100%);
      color: #e2e8f0;
    }

    .login-page {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2.2rem 1.2rem;
    }

    .login-shell {
      width: min(1080px, 100%);
      border-radius: 1.4rem;
      overflow: hidden;
      display: grid;
      grid-template-columns: 1.02fr 1fr;
      background: rgba(8, 16, 34, 0.86);
      border: 1px solid rgba(148, 163, 184, 0.2);
      box-shadow: 0 25px 65px rgba(2, 6, 23, 0.58);
      backdrop-filter: blur(8px);
    }

    .brand-side {
      padding: 2.5rem 2.3rem;
      background:
        linear-gradient(165deg, rgba(15, 23, 42, 0.94) 0%, rgba(30, 58, 138, 0.8) 100%);
      border-right: 1px solid rgba(148, 163, 184, 0.22);
      display: flex;
      flex-direction: column;
      gap: 1.6rem;
    }

    .brand-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.8rem;
      font-size: 0.86rem;
      letter-spacing: 0.11em;
      text-transform: uppercase;
      color: rgba(226, 232, 240, 0.86);
      font-weight: 600;
    }

    .brand-logo {
      width: 64px;
      height: 64px;
      border-radius: 14px;
      object-fit: contain;
      box-shadow: 0 10px 25px rgba(15, 23, 42, 0.35);
      background: rgba(255, 255, 255, 0.95);
      border: 1px solid rgba(226, 232, 240, 0.5);
      padding: 0.35rem;
    }

    .brand-side h1 {
      margin: 0;
      font-size: 1.95rem;
      line-height: 1.25;
      font-weight: 700;
      color: #f8fafc;
    }

    .brand-side p {
      margin: 0;
      color: rgba(226, 232, 240, 0.88);
      line-height: 1.65;
      max-width: 37ch;
    }

    .brand-points {
      margin-top: 0.4rem;
      display: grid;
      gap: 0.65rem;
      color: #dbeafe;
      font-size: 0.95rem;
    }

    .brand-points span {
      display: flex;
      gap: 0.55rem;
      align-items: center;
    }

    .brand-points i {
      color: #93c5fd;
      font-size: 0.95rem;
    }

    .brand-signature {
      margin-top: auto;
      padding-top: 1.2rem;
      border-top: 1px solid rgba(148, 163, 184, 0.2);
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(226, 232, 240, 0.68);
    }

    .form-side {
      background: linear-gradient(180deg, var(--surface) 0%, var(--surface-soft) 100%);
      color: var(--text-main);
      padding: 2.5rem 2.35rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .form-top {
      margin-bottom: 1.6rem;
    }

    .form-top .app-name {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      margin-bottom: 0.8rem;
      padding: 0.34rem 0.68rem;
      border-radius: 999px;
      border: 1px solid rgba(59, 130, 246, 0.28);
      background: rgba(59, 130, 246, 0.08);
      font-size: 0.75rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--brand-deep);
    }

    .form-top h2 {
      margin: 0;
      font-size: 1.7rem;
      font-weight: 700;
      color: var(--text-main);
    }

    .form-top p {
      margin: 0.5rem 0 0;
      color: var(--text-soft);
      line-height: 1.55;
    }

    .form-label {
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
      font-weight: 600;
      color: #1e293b;
    }

    .input-field {
      position: relative;
      margin-bottom: 1rem;
    }

    .input-field i {
      position: absolute;
      left: 0.9rem;
      top: 50%;
      transform: translateY(-50%);
      color: #64748b;
      font-size: 1rem;
    }

    .form-control {
      height: 49px;
      padding: 0.72rem 0.95rem 0.72rem 2.55rem;
      border-radius: 0.8rem;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--text-main);
      box-shadow: none;
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .form-control:focus {
      border-color: rgba(37, 99, 235, 0.6);
      box-shadow: 0 0 0 0.22rem rgba(59, 130, 246, 0.16);
    }

    .btn-login {
      width: 100%;
      border: none;
      border-radius: 0.82rem;
      height: 50px;
      background: linear-gradient(120deg, var(--brand) 0%, #2563eb 50%, #1e40af 100%);
      color: #fff;
      font-weight: 600;
      letter-spacing: 0.01em;
      box-shadow: 0 14px 30px rgba(37, 99, 235, 0.26);
      transition: transform 0.16s ease, box-shadow 0.16s ease;
    }

    .btn-login:hover {
      transform: translateY(-1px);
      box-shadow: 0 18px 34px rgba(37, 99, 235, 0.34);
    }

    .alert-danger {
      border: 1px solid rgba(185, 28, 28, 0.25);
      border-radius: 0.8rem;
      padding: 0.8rem 0.95rem;
      margin-bottom: 1rem;
      background: rgba(254, 226, 226, 0.68);
      color: var(--danger);
      font-size: 0.9rem;
    }

    .support-line {
      margin-top: 1.3rem;
      color: var(--text-soft);
      font-size: 0.88rem;
      text-align: center;
    }

    .support-line a {
      color: var(--brand-deep);
      font-weight: 600;
      text-decoration: none;
    }

    .support-line a:hover {
      text-decoration: underline;
    }

    @media (max-width: 920px) {
      .login-shell {
        grid-template-columns: 1fr;
      }

      .brand-side {
        border-right: none;
        border-bottom: 1px solid rgba(148, 163, 184, 0.24);
      }
    }

    @media (max-width: 576px) {
      .brand-side,
      .form-side {
        padding: 1.7rem 1.25rem;
      }

      .brand-side h1 {
        font-size: 1.6rem;
      }

      .form-top h2 {
        font-size: 1.4rem;
      }
    }
  </style>
</head>
<body>
  <main class="login-page">
    <section class="login-shell">
      <aside class="brand-side">
        <div class="brand-badge">
          <img src="/5754a6db-0563-4388-aba0-64eba64b2313.gif" alt="Logo GROUPE-BR" class="brand-logo">
          <span>GROUPE-BR</span>
        </div>

        <div>
          <h1>Pilotage opérationnel GROUPE-BR</h1>
          <p>
            Une plateforme de gestion fiable pour suivre le stock, les mouvements matériels
            et les opérations terrain avec une vision claire et maîtrisée.
          </p>
        </div>

        <div class="brand-points">
          <span><i class="bi bi-check2-circle"></i> Accès sécurisé aux données métier</span>
          <span><i class="bi bi-check2-circle"></i> Suivi centralisé dépôt, véhicules et chantiers</span>
          <span><i class="bi bi-check2-circle"></i> Interface conçue pour un usage professionnel quotidien</span>
        </div>

        <div class="brand-signature">GROUPE-BR · Gestion des stocks · Performance chantier</div>
      </aside>

      <section class="form-side">
        <div class="form-top">
          <div class="app-name">
            <i class="bi bi-shield-lock"></i> Espace GROUPE-BR
          </div>
          <h2>Connexion sécurisée</h2>
          <p>Renseignez vos identifiants professionnels pour accéder à votre environnement de pilotage.</p>
        </div>

        <% if (errors && errors.length > 0) { %>
          <div class="alert alert-danger">
            <% errors.forEach(function(error) { %>
              <p class="mb-0"><%= error %></p>
            <% }) %>
          </div>
        <% } %>

        <form action="/auth/login" method="POST">
          <label for="email" class="form-label">Adresse e-mail</label>
          <div class="input-field">
            <i class="bi bi-envelope"></i>
            <input
              type="email"
              name="email"
              id="email"
              class="form-control"
              placeholder="nom.prenom@batirenov.info"
              required
            >
          </div>

          <label for="password" class="form-label">Mot de passe</label>
          <div class="input-field">
            <i class="bi bi-key"></i>
            <input
              type="password"
              name="password"
              id="password"
              class="form-control"
              placeholder="••••••••"
              required
            >
          </div>

          <button type="submit" class="btn-login mt-2">
            <i class="bi bi-box-arrow-in-right me-1"></i>
            Se connecter à GROUPE-BR
          </button>
        </form>

        <div class="support-line">
          Besoin d'assistance ? <a href="mailto:support@batirenov.info">Contacter le support</a>
        </div>
      </section>
    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
